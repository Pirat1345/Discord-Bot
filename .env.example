# Ein zufälliger String für die Session-Verschlüsselung (z.B. openssl rand -hex 32)
SESSION_SECRET=change-me-to-a-random-string

# Discord Bot Token (optional – kann auch pro User im Panel gesetzt werden)
DISCORD_BOT_TOKEN=

# Die URL unter der das Panel erreichbar ist (z.B. http://192.168.1.50:3001)
FRONTEND_ORIGIN=http://localhost:3001
